# Copy this file to .env and fill in your email.
# .env is git-ignored and should never be committed.
#
# The setup script (scripts/setup.sh) will create and populate this file
# interactively. You can also edit it directly.
#
# On macOS, store your password in Keychain rather than here:
#   security add-generic-password -a "you@example.com" -s "phamerator_password" -w
# The scrape script reads it automatically when PHAMERATOR_EMAIL is set.

PHAMERATOR_EMAIL=you@example.com

# Only needed if not using Keychain (less secure — never commit this):
# PHAMERATOR_PASSWORD=yourpassword
