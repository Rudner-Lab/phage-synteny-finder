# Copy this file to .env and fill in your API key.
# .env is git-ignored and should never be committed.
#
# The setup script (scripts/setup.sh) can store your key in macOS Keychain
# instead — the scrape script reads it automatically from there.
#
# To store in Keychain (recommended on macOS):
#   security add-generic-password -a "phamerator" -s "phamerator_api_key" -w
#
# Otherwise, set it here (less secure — never commit this file with a real key):

PHAMERATOR_API_KEY=your_api_key_here
